# Google Gemini API Key - Get one from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Port to run the local Express web server
PORT=3000

# Resend API Key for Email Newsletter (optional)
# Get one from Resend: https://resend.com/
RE_API=your_resend_api_key_here

# Resend Sender Email (optional, defaults to onboarding@resend.dev)
# Once you verify your domain on Resend, change this to your custom domain email.
SENDER_EMAIL=onboarding@resend.dev
